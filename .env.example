# Public HTTPS endpoint ChatGPT will connect to.
MCP_DOMAIN=mcp.example.com
PUBLIC_URL=https://mcp.example.com

# OAuth/OIDC resource-server configuration. Do not commit real secrets here.
OIDC_ISSUER=https://issuer.example.com/
OIDC_AUDIENCE=agent-mcp
OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json

# Only this directory becomes available to the server.
WORKSPACES_DIR=./workspaces
PUID=1000
PGID=1000
