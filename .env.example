# Public HTTPS endpoint ChatGPT will connect to.
PUBLIC_URL=https://mcp.example.com

# Self-hosted Keycloak credentials. Generate unique random values and do not commit .env.
KEYCLOAK_DB_PASSWORD=replace-with-a-random-database-password
KEYCLOAK_ADMIN_USERNAME=mcp-admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-random-admin-password
KEYCLOAK_MCP_USERNAME=chatgpt
KEYCLOAK_MCP_PASSWORD=replace-with-a-random-chatgpt-login-password
KEYCLOAK_CHATGPT_CLIENT_SECRET=replace-with-a-random-chatgpt-client-secret

# Only this directory becomes available to the server.
WORKSPACES_DIR=./workspaces
PUID=1000
PGID=1000
DOCKER_GID=983

# Opt in only after provisioning the isolated clone with scripts/setup-self-improvement-workspace.sh.
ENABLE_SELF_IMPROVEMENT_WORKSPACE=false
SELF_IMPROVEMENT_WORKSPACE=agent-mcp

# Runtime resource lifecycle. Set a limit or TTL to 0 to disable it.
MAX_PROCESSES_PER_USER=32
MAX_BROWSER_SESSIONS_PER_USER=12
PROCESS_IDLE_TTL_SECONDS=14400
BROWSER_IDLE_TTL_SECONDS=7200
FINISHED_PROCESS_RETENTION_SECONDS=3600
RESOURCE_CLEANUP_INTERVAL_SECONDS=60
